<Project>

  <!-- Local-only overrides (e.g. RustManagedDir). Never committed. -->
  <Import Project="$(MSBuildThisFileDirectory)Directory.Build.User.props"
          Condition="Exists('$(MSBuildThisFileDirectory)Directory.Build.User.props')" />

  <PropertyGroup>
    <!-- Rust Dedicated Server managed assemblies. Populated by scripts/fetch-references.ps1
         (downloads SteamCMD, app 258550) into a git-ignored ./managed, or overridden in
         Directory.Build.User.props to point at an existing server install. -->
    <RustManagedDir Condition="'$(RustManagedDir)' == ''">$(MSBuildThisFileDirectory)managed</RustManagedDir>

    <LangVersion>11</LangVersion>
    <Deterministic>true</Deterministic>
  </PropertyGroup>

  <!-- Rust game assemblies for net48 plugin projects that opt in via ReferenceRustAssemblies.
       Excludes BCL dupes shipped in Unity's Managed folder and Carbon.* (from the NuGet package). -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net48' AND '$(ReferenceRustAssemblies)' == 'true'">
    <Reference Include="$(RustManagedDir)/*.dll"
               Exclude="$(RustManagedDir)/System*.dll;$(RustManagedDir)/mscorlib.dll;$(RustManagedDir)/netstandard.dll;$(RustManagedDir)/Mono.*.dll;$(RustManagedDir)/Microsoft.CSharp.dll;$(RustManagedDir)/I18N*.dll;$(RustManagedDir)/Carbon*.dll">
      <Private>false</Private>
    </Reference>
  </ItemGroup>

</Project>
